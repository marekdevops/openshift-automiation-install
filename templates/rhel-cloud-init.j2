#cloud-config
hostname: {{ vm_hostname }}
fqdn: {{ vm_hostname }}.{{ base_domain }}
manage_etc_hosts: true

users:
  - name: {{ ssh_user | default('cloud-user') }}
    groups: wheel
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - {{ lookup('file', ssh_public_key_file | default('~/.ssh/id_ed25519.pub')) | trim }}

chpasswd:
  expire: false

# Podstawowe pakiety instalowane przy pierwszym boocie
packages:
  - qemu-guest-agent
  - bash-completion
  - vim-enhanced

runcmd:
  - systemctl enable --now qemu-guest-agent
