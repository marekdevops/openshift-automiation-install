{% set registries_conf %}
[[registry]]
  prefix = ""
  location = "quay.io/openshift-release-dev/ocp-release"
  blocked = true
  insecure = false
  mirror-by-digest-only = true

  [[registry.mirror]]
    location = "{{ mirror_registry }}/openshift/release-images"
    insecure = false

[[registry]]
  prefix = ""
  location = "quay.io/openshift-release-dev/ocp-v4.0-art-dev"
  blocked = true
  insecure = false
  mirror-by-digest-only = true

  [[registry.mirror]]
    location = "{{ mirror_registry }}/openshift/release"
    insecure = false
{% endset %}
---
apiVersion: machineconfiguration.openshift.io/v1
kind: MachineConfig
metadata:
  labels:
    machineconfiguration.openshift.io/role: master
  name: 99-master-mirror-registries
spec:
  config:
    ignition:
      version: 3.2.0
    storage:
      files:
        - path: /etc/containers/registries.conf.d/99-mirror-blocked.conf
          mode: 0644
          overwrite: true
          contents:
            source: "data:text/plain;charset=utf-8;base64,{{ registries_conf | b64encode }}"
---
apiVersion: machineconfiguration.openshift.io/v1
kind: MachineConfig
metadata:
  labels:
    machineconfiguration.openshift.io/role: worker
  name: 99-worker-mirror-registries
spec:
  config:
    ignition:
      version: 3.2.0
    storage:
      files:
        - path: /etc/containers/registries.conf.d/99-mirror-blocked.conf
          mode: 0644
          overwrite: true
          contents:
            source: "data:text/plain;charset=utf-8;base64,{{ registries_conf | b64encode }}"
